# Per-Dockerfile ignore (BuildKit honors <dockerfile>.dockerignore over the
# context-root .dockerignore). The UI image builds from the REPO ROOT to reach
# the frozen ACI generated TS the @aci alias points at, so this trims the root
# context to what the Vite build needs -- the UI sources + lockfile and
# packages/aci-protocol/generated stay; everything else (the Python trees, the
# Rust CLI, the runner, docs, other packages, installed deps and build output)
# is dropped.
.git
**/node_modules
**/.venv
**/__pycache__
**/*.pyc
**/.mypy_cache
**/.pytest_cache
**/.ruff_cache
apps/ui/dist
apps/ui/test-results
apps/ui/playwright-report
apps/ui/.vite
apps/api
apps/dispatcher
apps/worker
runner
cli
docs
prototypes
charts
otel
scripts
tests
packages/plugin-format
packages/aci-protocol/src
packages/aci-protocol/tests
*.md
**/*.md
**/.env
