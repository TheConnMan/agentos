# apps/ui configuration. Copy to .env to override; all are optional.

# Proxy target for /api (dev server and preview forward /api here, stripping the
# prefix). Point this at the running apps/api uvicorn. This is a Vite process env
# var, read when the dev/preview server starts (not baked into the client build).
AGENTOS_API_TARGET=http://localhost:8000

# Build-time client flags (VITE_ prefix = exposed to the browser bundle).
# VITE_WIRED=1 makes the app talk to the real backend by default. Left unset,
# the app runs on fixtures and only wires when the URL carries ?api=1.
# VITE_WIRED=1

# There is deliberately no API-key setting here (#630 / ADR-0049). The console
# authenticates with a session cookie exchanged for a single-use login code from
# `agentos <local|cluster> console login`; the platform key is never given to
# browser code, so there is nothing to configure.
