              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_RUNNER_PORT",
          "producer": [
            "substrate"
          ],
          "title": "Port"
        },
        "runner_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_RUNNER_TOKEN",
          "producer": [
            "worker"
          ],
          "title": "Runner Token"
        },
        "session": {
          "$ref": "#/$defs/SessionConfig"
        },
        "state_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
