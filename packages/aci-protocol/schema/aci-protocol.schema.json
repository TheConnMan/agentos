{
  "$defs": {
    "Budget": {
      "description": "Per-agent budget spec, carried as JSON in AGENTOS_BUDGET.\n\n``task_budget_hint`` is the optional hint passed through to the model so it\nself paces (section 6b); it is not a hard ceiling.",
      "properties": {
        "max_output_tokens_per_run": {
          "title": "Max Output Tokens Per Run",
          "type": "integer"
        },
        "max_usd_per_day": {
          "title": "Max Usd Per Day",
          "type": "number"
        },
        "task_budget_hint": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Budget Hint"
        }
      },
      "required": [
        "max_output_tokens_per_run",
        "max_usd_per_day"
      ],
      "title": "Budget",
      "type": "object"
    },
    "ErrorEvent": {
      "description": "A classified failure surfaced to the platform.",
      "properties": {
        "classification": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Classification"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "type": {
          "const": "error",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "message",
        "type",
        "version"
      ],
      "title": "ErrorEvent",
      "type": "object"
    },
    "Event": {
      "description": "An inbound event delivered into a live session (initial or follow-up).",
      "properties": {
        "kind": {
          "const": "event",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "ts": {
          "title": "Ts",
          "type": "string"
        },
        "type": {
          "enum": [
            "message",
            "job",
            "eval_case"
          ],
          "title": "Type",
          "type": "string"
        },
        "user": {
          "title": "User",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "text",
        "ts",
        "type",
        "user"
      ],
      "title": "Event",
      "type": "object"
    },
    "Final": {
      "description": "The terminal response event, carrying the session status.\n\n``approval_summary`` accompanies an ``awaiting-approval`` status (ADR-0010):\nthe human-readable statement of what needs approval, captured from the\nrun's approval request so the platform can persist it on the durable\n``Approval`` record and show it to the approver. ``approval_route`` names\nthe approval route the request targets (#247): declared in the bundle\nmanifest's ``approvalPolicy`` (versioned with the agent), bound to a\nworkspace channel per deployment by the worker. Both ``None`` on every\nother status; ``approval_route`` also ``None`` when the request named no\nroute (the platform falls back to the requesting channel).",
      "properties": {
        "approval_route": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approval Route"
        },
        "approval_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approval Summary"
        },
        "status": {
          "$ref": "#/$defs/SessionStatus",
          "default": "done"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "final",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type",
        "version"
      ],
      "title": "Final",
      "type": "object"
    },
    "InboundMessage": {
      "discriminator": {
        "mapping": {
          "event": "#/$defs/Event",
          "interrupt": "#/$defs/Interrupt"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/Event"
        },
        {
          "$ref": "#/$defs/Interrupt"
        }
      ],
      "title": "InboundMessage"
    },
    "Interrupt": {
      "description": "A hard stop delivered on the control channel, distinct from a steer.",
      "properties": {
        "kind": {
          "const": "interrupt",
          "title": "Kind",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "reason"
      ],
      "title": "Interrupt",
      "type": "object"
    },
    "OtelConfig": {
      "description": "The OTEL_EXPORTER_OTLP_* subset the runner needs to export traces.\n\nSection 0 lists OTEL_EXPORTER_OTLP_* as a wildcard. We capture the standard\nfields the prototype used (endpoint, headers, protocol); any others pass\nthrough as raw env vars untouched and are out of scope for this typed view.",
      "properties": {
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "headers": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headers"
        },
        "protocol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Protocol"
        }
      },
      "title": "OtelConfig",
      "type": "object"
    },
    "OutboundEvent": {
      "discriminator": {
        "mapping": {
          "error": "#/$defs/ErrorEvent",
          "final": "#/$defs/Final",
          "side_effect_flag": "#/$defs/SideEffectFlag",
          "text_delta": "#/$defs/TextDelta",
          "tool_note": "#/$defs/ToolNote"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/TextDelta"
        },
        {
          "$ref": "#/$defs/ToolNote"
        },
        {
          "$ref": "#/$defs/Final"
        },
        {
          "$ref": "#/$defs/ErrorEvent"
        },
        {
          "$ref": "#/$defs/SideEffectFlag"
        }
      ],
      "title": "OutboundEvent"
    },
    "QueuedTurn": {
      "description": "A normalized inbound turn ready for the worker to route and run.\n\nThe channel-neutral promotion of the dispatcher's former ``QueuedSlackEvent``.\nThe Valkey Stream carries this model as a single ``payload`` JSON field; the\nstream-encoding helpers live with the producer (the dispatcher), not on this\nfrozen model, so the contract stays transport-agnostic.",
      "properties": {
        "author": {
          "title": "Author",
          "type": "string"
        },
        "conversation_id": {
          "title": "Conversation Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "received_at": {
          "title": "Received At",
          "type": "string"
        },
        "reply_handle": {
          "$ref": "#/$defs/ReplyHandle"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "author",
        "conversation_id",
        "event_id",
        "received_at",
        "reply_handle",
        "text"
      ],
      "title": "QueuedTurn",
      "type": "object"
    },
    "ReplyHandle": {
      "description": "Channel-neutral coordinates for where a turn's reply is delivered.\n\nThe reply model is edit-in-place: the ingress adapter pre-posts a placeholder\nmessage and the worker edits it as the answer streams. For the Slack adapter\ntoday, ``channel`` is the Slack channel id (also the key the deployment\nbinding matches an agent on) and ``placeholder`` is the ts of the pre-posted\nplaceholder message.\n\n``endpoint`` is the per-turn reply target: the base URL of the channel API the\nworker delivers this turn's reply through. It routes the reply back to the\ningress that enqueued the turn instead of a worker-global setting, so two\ningress paths (a real Slack workspace and a no-Slack CLI stub) can coexist on\none worker (issue #19). ``None`` means \"use the worker's configured default\"\n(its ``slack_api_base_url``, i.e. real Slack), so a producer that does not set\nit keeps the pre-#19 behavior.",
      "properties": {
        "channel": {
          "title": "Channel",
          "type": "string"
        },
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "placeholder": {
          "title": "Placeholder",
          "type": "string"
        }
      },
      "required": [
        "channel",
        "placeholder"
      ],
      "title": "ReplyHandle",
      "type": "object"
    },
    "SessionConfig": {
      "description": "The typed session setup contract.\n\n``credentials_ref`` is a reference to injected secrets (AGENTOS_CREDENTIALS);\nsection 0 describes these as per-tool secrets via K8s Secret refs, so the\ncontract carries the reference, not the secret material itself.",
      "properties": {
        "budget": {
          "$ref": "#/$defs/Budget"
        },
        "credentials_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Credentials Ref"
        },
        "memory_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Ref"
        },
        "otel": {
          "$ref": "#/$defs/OtelConfig"
        },
        "plugin_dir": {
          "title": "Plugin Dir",
          "type": "string"
        },
        "sandbox_id": {
          "title": "Sandbox Id",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        }
      },
      "required": [
        "budget",
        "plugin_dir",
        "sandbox_id",
        "session_id"
      ],
      "title": "SessionConfig",
      "type": "object"
    },
    "SessionStatus": {
      "description": "Terminal or awaiting status of a session, from the output contract.\n\nWire tokens follow the section 0 spelling; ``classified failure`` in prose\nbecomes the token ``classified-failure`` on the wire.",
      "enum": [
        "done",
        "idle-awaiting-input",
        "classified-failure",
        "awaiting-approval"
      ],
      "title": "SessionStatus",
      "type": "string"
    },
    "SideEffectFlag": {
      "description": "Marks that a non-idempotent tool call executed during the run.\n\nIts presence gates the no-retry-after-side-effects rule (section 2b): a\nfailed run carrying this flag escalates to a human instead of retrying.",
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool"
        },
        "type": {
          "const": "side_effect_flag",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "type",
        "version"
      ],
      "title": "SideEffectFlag",
      "type": "object"
    },
    "TextDelta": {
      "description": "A streamed chunk of assistant text.",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "text_delta",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type",
        "version"
      ],
      "title": "TextDelta",
      "type": "object"
    },
    "ToolNote": {
      "description": "A human readable note about a tool call the harness is making.",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool"
        },
        "type": {
          "const": "tool_note",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type",
        "version"
      ],
      "title": "ToolNote",
      "type": "object"
    }
  },
  "$id": "https://curie.tech/agentos/aci-protocol.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocolVersion": "0.2.0",
  "title": "ACI Protocol v0.2.0"
}
