            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_FAKE_MODEL",
          "producer": [
            "worker",
            "substrate"
          ],
          "title": "Fake Model"
        },
        "history_max_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_HISTORY_MAX_BYTES",
          "producer": [
            "operator"
          ],
          "title": "History Max Bytes"
        },
        "history_max_turns": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_HISTORY_MAX_TURNS",
          "producer": [
            "operator"
          ],
          "title": "History Max Turns"
        },
        "history_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_HISTORY_REF",
          "producer": [
            "worker"
          ],
          "title": "History Ref"
        },
        "history_token": {
          "anyOf": [
            {
              "type": "string"
