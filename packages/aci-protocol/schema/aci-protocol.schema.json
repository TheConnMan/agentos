            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_MODEL",
          "producer": [
            "worker",
            "substrate"
          ],
          "title": "Model"
        },
        "model_env_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_MODEL_ENV_KEY",
          "producer": [
            "worker"
          ],
          "title": "Model Env Key"
        },
        "port": {
