      "properties": {
        "agent_id": {
          "format": "uuid",
          "title": "Agent Id",
          "type": "string"
        },
        "bundle_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Bundle Ref"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
