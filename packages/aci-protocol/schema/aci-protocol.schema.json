{
  "$defs": {
    "ApprovalRequest": {
      "description": "A durable approval request (#244), created by the worker when a run ends\nawaiting-approval.\n\n``dedupe_key`` is the triggering event id, so a redelivered turn adopts the\nexisting record instead of forking a second one. ``route``/``card_channel``\n(#247) record the manifest route the request named and the channel the worker\nrouted the card to after binding resolution; the authorizer proves membership\nagainst ``card_channel``. ``gate_kind``/``granted_tool`` are the durable gate\nprovenance (#544, Decision C) written by the runner; both stay optional for\nthe rolling-deploy window.",
      "properties": {
        "agent_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Id"
        },
        "author": {
          "minLength": 1,
          "title": "Author",
          "type": "string"
        },
        "card_channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Card Channel"
        },
        "conversation_id": {
          "minLength": 1,
          "title": "Conversation Id",
          "type": "string"
        },
        "dedupe_key": {
          "minLength": 1,
          "title": "Dedupe Key",
          "type": "string"
        },
        "expires_in_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires In Seconds"
        },
        "gate_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/GateKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "granted_tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Granted Tool"
        },
        "reply_channel": {
          "minLength": 1,
          "title": "Reply Channel",
          "type": "string"
        },
        "reply_endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reply Endpoint"
        },
        "reply_placeholder": {
          "minLength": 1,
          "title": "Reply Placeholder",
          "type": "string"
        },
        "route": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Route"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "author",
        "conversation_id",
        "dedupe_key",
        "reply_channel",
        "reply_placeholder",
        "summary"
      ],
      "title": "ApprovalRequest",
      "type": "object"
    },
    "BootEnv": {
      "description": "The full worker-to-runner boot env: the ACI session plus platform ops.\n\n``session`` COMPOSES the frozen ``SessionConfig`` rather than extending it.\nThat nesting is the ACI-vs-platform boundary: a runner token, approval\nplumbing, and a history port are AgentOS platform operations, not the\ninterface a third-party ACI-conformant runner implements. Inheriting would\ntell every future implementer otherwise (ADR-0049).\n\n**Multiple producers, one consumer.** The boot env is assembled by the worker\nbinding, the worker kernel's resume overlay, the substrate (chart/docker),\nand the operator; only the runner consumes it. So ``from_env`` is the single\nconsumer parse of the whole union, while rendering is per-producer: there is\ndeliberately no whole-model ``to_env`` on the wire path. ``render_worker`` is\nthe one real render surface; ``to_env`` exists for round-trip checks only.\n\n**Authority, not arity, is the invariant.** ``AGENTOS_SANDBOX_ID`` and\n``AGENTOS_RUNNER_PORT`` are substrate-authoritative: identity derives from\nthe pod name (``fieldRef: metadata.name``), and because the chart sets\n``envVarsInjectionPolicy: Overrides`` a worker write would REPLACE it and\nbreak the \"pod name IS the sandbox id\" invariant that trace stamping relies\non. ``ANTHROPIC_BASE_URL`` is also multi-producer, but there the worker is\nauthoritative and worker-wins is the intended layering: the chart branch is a\nbaked template default, the worker's value is per-agent model routing. Do not\ncollapse either producer list to a single value.",
      "properties": {
        "api_backend": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_MODEL_API_BACKEND",
          "producer": [
            "worker"
          ],
          "title": "Api Backend"
        },
        "approval_decision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_APPROVAL_DECISION",
          "producer": [
            "kernel"
          ],
          "title": "Approval Decision"
        },
        "approval_grant_tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_APPROVAL_GRANT_TOOL",
          "producer": [
            "kernel"
          ],
          "title": "Approval Grant Tool"
        },
        "approval_required_tools": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_APPROVAL_REQUIRED_TOOLS",
          "producer": [
            "worker"
          ],
          "title": "Approval Required Tools"
        },
        "approval_resumed_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_APPROVAL_RESUMED_KIND",
          "producer": [
            "kernel"
          ],
          "title": "Approval Resumed Kind"
        },
        "base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "ANTHROPIC_BASE_URL",
          "producer": [
            "worker",
            "substrate"
          ],
          "title": "Base Url"
        },
        "bundle_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_BUNDLE_REF",
          "producer": [
            "worker"
          ],
          "title": "Bundle Ref"
        },
        "connector_secret_keys": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "env": "AGENTOS_CONNECTOR_SECRET_KEYS",
          "producer": [
            "worker"
          ],
          "title": "Connector Secret Keys"
        },
        "fake_model": {
