{
  "$defs": {
    "Author": {
      "additionalProperties": true,
      "description": "The plugin manifest author object (or it may be a plain string).",
      "properties": {
        "email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Email"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "required": [
        "name"
      ],
      "title": "Author",
      "type": "object"
    },
    "HookDefinition": {
      "additionalProperties": true,
      "description": "One hook action inside a matcher's ``hooks`` list.\n\nThe Claude Code plugin ``hooks`` shape: a single action of a given ``type``.\nToday only ``type: \"command\"`` exists (run a shell command); ``command`` is\nrequired for it. Kept lenient so a future hook type still validates, but the\ndeploy-time validator (``validate.py``) enforces that a ``command`` hook\nactually carries a command so a malformed guardrail is caught before ship.",
      "properties": {
        "command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "HookDefinition",
      "type": "object"
    },
    "HookMatcherConfig": {
      "additionalProperties": true,
      "description": "One matcher entry under a hook event (e.g. ``PreToolUse``).\n\n``matcher`` is a tool-name pattern (``\"Bash\"``, ``\"Write|Edit\"``; absent or\nempty means \"all tools\"); ``hooks`` is the list of actions to run when a tool\ncall matches. Mirrors the Claude Code hooks structure verbatim.",
      "properties": {
        "hooks": {
          "items": {
            "$ref": "#/$defs/HookDefinition"
          },
          "title": "Hooks",
          "type": "array"
        },
        "matcher": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matcher"
        }
      },
      "title": "HookMatcherConfig",
      "type": "object"
    },
    "McpConfig": {
      "additionalProperties": true,
      "description": "The `.mcp.json` document.",
      "properties": {
        "mcpServers": {
          "additionalProperties": {
            "$ref": "#/$defs/McpServer"
          },
          "title": "Mcpservers",
          "type": "object"
        }
      },
      "title": "McpConfig",
      "type": "object"
    },
    "McpServer": {
      "additionalProperties": true,
      "description": "One entry in `.mcp.json` mcpServers.\n\nA single permissive model rather than a strict stdio-vs-remote union, to\nstay forward compatible with Claude Code's evolving server shapes. A stdio\nserver carries ``command`` (plus optional ``args``/``env``); a remote server\ncarries ``type`` and ``url``. The validator enforces that one of the two is\npresent.",
      "properties": {
        "args": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Args"
        },
        "command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command"
        },
        "env": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Env"
        },
        "headers": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headers"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Type"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "title": "McpServer",
      "type": "object"
    },
    "PluginManifest": {
      "additionalProperties": true,
      "description": "The `.claude-plugin/plugin.json` manifest.\n\nOnly ``name`` is required by the Claude Code format; everything else is\noptional. ``commands``/``agents`` may be a single path or a list; ``hooks``\nand ``mcpServers`` may be a path string or an inline object.",
      "properties": {
        "agents": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agents"
        },
        "author": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/Author"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Author"
        },
        "commands": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commands"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "homepage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Homepage"
        },
        "hooks": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hooks"
        },
        "keywords": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keywords"
        },
        "license": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        },
        "mcpServers": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mcpservers"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "repository": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repository"
        },
        "systemPrompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Systemprompt"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "PluginManifest",
      "type": "object"
    },
    "SkillFrontmatter": {
      "additionalProperties": true,
      "description": "The YAML frontmatter of a `skills/<name>/SKILL.md` file.\n\n``name`` and ``description`` are required. The tool restriction field is the\nverbatim Claude Code key ``allowed-tools`` (see the package README Decisions\nfor why this differs from the task's shorthand \"tools\").",
      "properties": {
        "allowed-tools": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allowed-Tools"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "SkillFrontmatter",
      "type": "object"
    }
  },
  "$id": "https://curie.tech/agentos/plugin-format.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Plugin Format"
}
