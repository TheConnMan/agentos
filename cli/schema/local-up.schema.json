{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curietech.ai/cli/local-up/v1.json",
  "title": "curie local up --json",
  "description": "The agent-facing payload of `curie local up`: the dry-run plan, or the started dev stack's advertised endpoints and Slack wiring state.",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "const": "up"
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "url"
            ]
          }
        },
        "slack": {
          "type": "boolean"
        }
      },
      "required": [
        "status",
        "endpoints",
        "slack"
      ]
    }
  ]
}
