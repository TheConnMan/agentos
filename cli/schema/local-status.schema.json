{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curietech.ai/cli/local-status/v1.json",
  "title": "curie local status --json",
  "description": "The agent-facing payload of `curie local status`: the dry-run plan, or the `docker compose ps` output as one line per service.",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "services"
      ]
    }
  ]
}
