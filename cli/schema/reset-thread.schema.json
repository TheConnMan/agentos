{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curie.dev/cli/reset-thread/v1.json",
  "title": "curie <tier> reset-thread --json",
  "description": "The agent-facing payload of `curie <tier> reset-thread`: the dry-run plan, or the reset-request state (`requested` always true on success; `released` true only once the worker confirmed the sandbox drained within the wait window).",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string"
        },
        "thread_key": {
          "type": "string"
        },
        "requested": {
          "type": "boolean"
        },
        "released": {
          "type": "boolean"
        }
      },
      "required": [
        "agent",
        "thread_key",
        "requested",
        "released"
      ]
    }
  ]
}
