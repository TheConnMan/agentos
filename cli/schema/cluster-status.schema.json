{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentos.dev/cli/cluster-status/v1.json",
  "title": "agentos cluster status --json",
  "description": "The agent-facing payload of `agentos cluster status`: the dry-run plan, or the release's revision, pod readiness roll-up (with per-pod rows and the unhealthy names), discovered service URLs (a degraded surface carries a `note` and a null `url`), and an overall `healthy` verdict.",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "release_state": {
          "type": "string"
        },
        "release_found": {
          "type": "boolean"
        },
        "pods": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ready": {
              "type": "integer"
            },
            "total": {
              "type": "integer"
            },
            "unhealthy": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "pod": {
                    "type": "string"
                  },
                  "ready": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  }
                },
                "required": [
                  "pod",
                  "ready",
                  "status"
                ]
              }
            }
          },
          "required": [
            "ready",
            "total",
            "unhealthy",
            "rows"
          ]
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "note": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "name",
              "url",
              "note"
            ]
          }
        },
        "healthy": {
          "type": "boolean"
        }
      },
      "required": [
        "namespace",
        "revision",
        "release_state",
        "release_found",
        "pods",
        "urls",
        "healthy"
      ]
    }
  ]
}
