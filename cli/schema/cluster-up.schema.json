{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curietech.ai/cli/cluster-up/v1.json",
  "title": "curie cluster up --json",
  "description": "The agent-facing payload of `curie cluster up`: the dry-run plan, or the installed release's namespace and name.",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "const": "up"
        },
        "namespace": {
          "type": "string"
        },
        "release": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "namespace",
        "release"
      ]
    }
  ]
}
