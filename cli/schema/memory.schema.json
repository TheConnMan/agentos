{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentos.dev/cli/memory/v1.json",
  "title": "agentos <tier> memory --json",
  "description": "The agent-facing payload of `agentos <tier> memory <agent>`: the dry-run plan, or the learned-memory entries (an empty array when none exist).",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "index": {
                "type": "integer"
              },
              "content": {
                "type": "string"
              }
            },
            "required": [
              "index",
              "content"
            ]
          }
        }
      },
      "required": [
        "agent",
        "entries"
      ]
    }
  ]
}
