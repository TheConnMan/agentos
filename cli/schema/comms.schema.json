{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curie.dev/cli/comms/v1.json",
  "title": "curie <tier> comms --json",
  "description": "The agent-facing payload of `curie local comms` / `curie cluster comms`: the dry-run plan, or the resulting Slack wiring state.",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connected": {
          "type": "boolean"
        }
      },
      "required": [
        "connected"
      ]
    }
  ]
}
