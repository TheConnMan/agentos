{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curietech.ai/cli/budget/v1.json",
  "title": "curie <tier> budget --json",
  "description": "The agent-facing payload of `curie <tier> budget <agent>`: the dry-run plan, or the saved budget (`max_usd_per_day` is null when the platform default applies).",
  "$defs": {
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dry_run": {
          "const": true
        },
        "plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "dry_run",
        "plan"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/dryRun"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string"
        },
        "max_usd_per_day": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "agent",
        "max_usd_per_day"
      ]
    }
  ]
}
